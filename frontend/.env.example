# Copy to .env.local and fill in real values for local development.
# .env.local is gitignored. Never commit real tokens or client IDs you want
# scoped to a specific environment.

# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:5249

# SignalR hubs base URL (usually API host + /hubs)
NEXT_PUBLIC_SIGNALR_URL=http://localhost:5249/hubs

# Azure AD app registration (Entra ID) for single-sign-on via MSAL
NEXT_PUBLIC_AZURE_AD_CLIENT_ID=00000000-0000-0000-0000-000000000000
NEXT_PUBLIC_AZURE_AD_TENANT_ID=00000000-0000-0000-0000-000000000000
