# Azure AD / Entra ID
AzureAd__TenantId=your-tenant-id
AzureAd__ClientId=your-client-id
AzureAd__Audience=api://your-client-id

# Database
ConnectionStrings__DefaultConnection=Server=your-server.database.windows.net;Database=SoftimProject;Authentication=Active Directory Default

# Azure Blob Storage
AzureBlobStorage__ConnectionString=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key
AzureBlobStorage__ContainerName=attachments

# Azure OpenAI
AzureOpenAI__Endpoint=https://your-resource.openai.azure.com/
AzureOpenAI__DeploymentName=gpt-4o
AzureOpenAI__ApiKey=your-key

# Frontend URL (for CORS)
Frontend__BaseUrl=http://localhost:3000

# Email-to-ticket sync (#49). Disabled by default; set Sync__Email__Enabled=true after
# provisioning an Entra app with Mail.ReadWrite application permission on the mailbox.
Sync__Email__Enabled=false
Sync__Email__TenantId=your-tenant-id
Sync__Email__ClientId=your-app-client-id
Sync__Email__ClientSecret=your-app-client-secret
Sync__Email__MailboxUserId=inbox@yourdomain.com
Sync__Email__AliasPrefix=inbox+
Sync__Email__BatchSize=50
